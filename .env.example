# =============================================================================
# Athar Nur Travels — Environment Variables
# =============================================================================
# Copy this file to .env.local for development.
# In production (cPanel), set these via "Setup Node.js App" → "Environment
# variables" — DO NOT commit secrets to git.

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# MongoDB Atlas connection string.
# Create a free cluster at https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/atharnur-travels?retryWrites=true&w=majority

# NextAuth signing secret. MUST be at least 32 characters.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-32-or-more-random-chars-aaaaaaaaa

# Public URL of the deployed app (no trailing slash). Used by NextAuth for callbacks.
NEXTAUTH_URL=https://www.atharnurtravels.com

# Admin login credentials — used by NextAuth's Credentials provider.
ADMIN_EMAIL=admin@atharnurtravels.com
ADMIN_PASSWORD=use-a-long-passphrase-here

# Cloudinary credentials (for admin image uploads).
# Get yours from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Public app URL (used by the frontend for absolute links)
NEXT_PUBLIC_APP_URL=https://www.atharnurtravels.com

# Public WhatsApp number for the floating button and enquiry CTAs.
# Format: country code + number, no leading + or spaces (e.g. 8801843431743).
NEXT_PUBLIC_WHATSAPP_NUMBER=8801843431743

# -----------------------------------------------------------------------------
# OPTIONAL — leave unset until you wire them up
# -----------------------------------------------------------------------------

# Gmail SMTP (use a Google App Password, NOT your account password).
# https://myaccount.google.com/apppasswords
# GMAIL_USER=your-gmail@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Generic SMTP fallback (if not using Gmail)
# SMTP_HOST=mail.atharnurtravels.com
# SMTP_PORT=465
# SMTP_USER=info@atharnurtravels.com
# SMTP_PASSWORD=mailbox-password

# -----------------------------------------------------------------------------
# ONLINE PAYMENT GATEWAY
# -----------------------------------------------------------------------------
# The "Pay Online" option works with EITHER gateway below. Configure one (or
# both) and the app routes checkout through the active gateway automatically.
#
# PAYMENT_GATEWAY selects which one to use:
#   - unset / "auto" → SSLCommerz if its store creds are set, else PipraPay
#   - "sslcommerz"   → force SSLCommerz (only if configured)
#   - "piprapay"     → force PipraPay (only if configured)
# PAYMENT_GATEWAY=auto

# SSLCommerz — set BOTH store id + password to enable. Flip IS_LIVE to true for
# production (uses securepay.sslcommerz.com instead of the sandbox).
# SSLCOMMERZ_STORE_ID=your-store-id
# SSLCOMMERZ_STORE_PASSWORD=your-store-password
# SSLCOMMERZ_IS_LIVE=false

# PipraPay payment gateway (open-source, self-hosted hosted-checkout).
# Base URL: use the sandbox while testing, then your self-hosted live domain.
#   Sandbox: https://sandbox.piprapay.com
#   Live:    https://pay.atharnurtravels.com   (your self-hosted instance)
# Get the API key from your PipraPay dashboard. The SAME key is used both to
# authenticate outgoing requests and to validate the mh-piprapay-api-key header
# on incoming webhooks — keep it secret.
# PIPRAPAY_BASE_URL=https://sandbox.piprapay.com
# PIPRAPAY_API_KEY=your-piprapay-api-key
# PIPRAPAY_CURRENCY=BDT

# --------------------
#   To turn each on
#   # Use SSLCommerz:
#   PAYMENT_GATEWAY=sslcommerz        # optional; auto-detected if creds set
#   SSLCOMMERZ_STORE_ID=your-store-id
#   SSLCOMMERZ_STORE_PASSWORD=your-store-password
#   SSLCOMMERZ_IS_LIVE=true           # false = sandbox

  # Use PipraPay:
#   PAYMENT_GATEWAY=piprapay
#   PIPRAPAY_BASE_URL=https://sandbox.piprapay.com
#   PIPRAPAY_API_KEY=your-key

#   Plus NEXT_PUBLIC_APP_URL must be your real public origin — all callback/IPN/webhook URLs are built from it, and SSLCommerz/PipraPay servers must be able to reach them (use a tunnel like cloudflared for local testing).